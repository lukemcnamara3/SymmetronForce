Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"Non", "-", 
     RowBox[{"coincidence", " ", "limit", " ", 
      RowBox[{"Green", "'"}], "s", " ", "function", " ", "for", " ", "l"}]}], 
    " ", "=", " ", "0"}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{"l", "=", "0"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"inner", "=", 
     RowBox[{"NDSolveValue", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"w", "''"}], "[", "r", "]"}], "+", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{
              RowBox[{"w", "'"}], "[", "r", "]"}], ")"}], "^", "2"}], "-", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"l", " ", 
              RowBox[{"(", 
               RowBox[{"l", "+", "1"}], ")"}]}], ")"}], "/", 
            RowBox[{"r", "^", "2"}]}], "+", 
           RowBox[{"g", "[", "r", "]"}]}], "==", "0"}], ",", 
         RowBox[{
          RowBox[{"w", "[", "xmin", "]"}], "==", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"l", "+", "1"}], ")"}], "*", 
           RowBox[{"Log", "[", "xmin", "]"}]}]}], ",", 
         RowBox[{
          RowBox[{
           RowBox[{"w", "'"}], "[", "xmin", "]"}], "==", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"l", "+", "1"}], ")"}], "/", "xmin"}]}]}], "}"}], ",", 
       "w", ",", 
       RowBox[{"{", 
        RowBox[{"r", ",", "xmin", ",", "xmax"}], "}"}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"outer", "=", 
     RowBox[{"NDSolveValue", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"w", "''"}], "[", "r", "]"}], "+", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{
              RowBox[{"w", "'"}], "[", "r", "]"}], ")"}], "^", "2"}], "-", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"l", " ", 
              RowBox[{"(", 
               RowBox[{"l", "+", "1"}], ")"}]}], ")"}], "/", 
            RowBox[{"r", "^", "2"}]}], "+", 
           RowBox[{"g", "[", "r", "]"}]}], "==", "0"}], ",", 
         RowBox[{
          RowBox[{"w", "[", "xmax", "]"}], "==", 
          RowBox[{
           RowBox[{
            RowBox[{"-", 
             RowBox[{"(", 
              RowBox[{"Sqrt", "[", 
               RowBox[{"1", "/", "2"}], "]"}], ")"}]}], "*", "xmax"}], "+", 
           RowBox[{"Log", "[", "xmax", "]"}]}]}], ",", 
         RowBox[{
          RowBox[{
           RowBox[{"w", "'"}], "[", "xmax", "]"}], "==", 
          RowBox[{
           RowBox[{"-", 
            RowBox[{"(", 
             RowBox[{"Sqrt", "[", 
              RowBox[{"1", "/", "2"}], "]"}], ")"}]}], "+", 
           RowBox[{"1", "/", "xmax"}]}]}]}], "}"}], ",", "w", ",", 
       RowBox[{"{", 
        RowBox[{"r", ",", "xmin", ",", "xmax"}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"inner1", "[", 
      RowBox[{"x_", "?", "NumericQ"}], "]"}], ":=", 
     RowBox[{"inner", "[", "x", "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"outer1", "[", 
      RowBox[{"x_", "?", "NumericQ"}], "]"}], ":=", 
     RowBox[{"outer", "[", "x", "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"inner1prime", "[", 
      RowBox[{"x_", "?", "NumericQ"}], "]"}], ":=", 
     RowBox[{
      RowBox[{"inner", "'"}], "[", "x", "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"outer1prime", "[", 
      RowBox[{"x_", "?", "NumericQ"}], "]"}], ":=", 
     RowBox[{
      RowBox[{"outer", "'"}], "[", "x", "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"fInner", "[", 
      RowBox[{"x_", "?", "NumericQ"}], "]"}], ":=", 
     RowBox[{
      RowBox[{"Exp", "[", 
       RowBox[{"inner1", "[", "x", "]"}], "]"}], "/", "x"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"fOuter", "[", 
      RowBox[{"x_", "?", "NumericQ"}], "]"}], ":=", 
     RowBox[{
      RowBox[{"Exp", "[", 
       RowBox[{"outer1", "[", "x", "]"}], "]"}], "/", "x"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"fInnerp", "[", 
      RowBox[{"x_", "?", "NumericQ"}], "]"}], ":=", 
     RowBox[{
      RowBox[{
       RowBox[{"inner1prime", "[", "x", "]"}], "*", 
       RowBox[{"fInner", "[", "x", "]"}]}], "-", 
      RowBox[{
       RowBox[{"fInner", "[", "x", "]"}], "/", "x"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"fOuterp", "[", 
      RowBox[{"x_", "?", "NumericQ"}], "]"}], ":=", 
     RowBox[{
      RowBox[{
       RowBox[{"outer1prime", "[", "x", "]"}], "*", 
       RowBox[{"fOuter", "[", "x", "]"}]}], "-", 
      RowBox[{
       RowBox[{"fOuter", "[", "x", "]"}], "/", "x"}]}]}], ";"}], "\n", 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"fWrons", "[", 
      RowBox[{"x_", "?", "NumericQ"}], "]"}], ":=", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"fInner", "[", "x", "]"}], "*", 
         RowBox[{"fOuterp", "[", "x", "]"}]}], "-", 
        RowBox[{
         RowBox[{"fOuter", "[", "x", "]"}], "*", 
         RowBox[{"fInnerp", "[", "x", "]"}]}]}], ")"}], "*", 
      RowBox[{"(", 
       RowBox[{"x", "^", "2"}], ")"}]}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"G0", "[", 
      RowBox[{
       RowBox[{"r_", "?", "NumericQ"}], ",", 
       RowBox[{"rp_", "?", "NumericQ"}]}], "]"}], ":=", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"r", "<=", "rp"}], ",", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"fInner", "[", "r", "]"}], "*", 
          RowBox[{"fOuter", "[", "rp", "]"}]}], ")"}], "/", 
        RowBox[{"fWrons", "[", "r", "]"}]}], ",", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"fInner", "[", "rp", "]"}], "*", 
          RowBox[{"fOuter", "[", "r", "]"}]}], ")"}], "/", 
        RowBox[{"fWrons", "[", "rp", "]"}]}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"Correction", "[", 
      RowBox[{"x_", "?", "NumericQ"}], "]"}], ":=", 
     RowBox[{"NIntegrate", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"G0", "[", 
         RowBox[{"x", ",", "y"}], "]"}], "*", 
        RowBox[{"y", "^", "2"}], "*", 
        RowBox[{"Cfield", "[", "y", "]"}], "*", 
        RowBox[{"RenormalisedField", "[", "y", "]"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"y", ",", "xmin", ",", "xmax"}], "}"}], ",", 
       RowBox[{"Method", "->", "\"\<GlobalAdaptive\>\""}], ",", 
       RowBox[{"MaxRecursion", "->", "12"}], ",", 
       RowBox[{"AccuracyGoal", "->", "6"}], ",", 
       RowBox[{"PrecisionGoal", "->", "6"}]}], "]"}]}], ";"}], " ", 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"QuantumField", "[", 
      RowBox[{"x_", "?", "NumericQ"}], "]"}], " ", ":=", " ", 
     RowBox[{
      RowBox[{"Cfield", "[", "x", "]"}], " ", "-", " ", 
      RowBox[{"Correction", "[", "x", "]"}]}]}], ";"}], " ", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
     "Integrate", " ", "and", " ", "compute", " ", "quantum", " ", 
      "correction"}], ",", " ", 
     RowBox[{
     "note", " ", "that", " ", "sign", " ", "comes", " ", "from", " ", "just",
       " ", "how", " ", "we", " ", "computed", " ", "the", " ", 
      RowBox[{"Green", "'"}], "s"}]}], "*)"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]"}]}]], "Input",
