        RowBox[{"x", ",", "xvals"}], "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"outpath", "=", 
     RowBox[{"FileNameJoin", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"NotebookDirectory", "[", "]"}], 
        ",", "\"\<renormalised.txt\>\""}], "}"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
